# Harbor task config generated by eval-dataset from eval.yaml.
# Placeholders use @@NAME@@ so the template stays valid TOML-ish and avoids
# clashing with shell/format brace syntax.
schema_version = "1.3"

[task]
name = "@@TASK_NAME@@"
description = "@@TASK_DESC@@"

[metadata]
generated_by = "agent-eval-harness/eval-dataset"
eval_name = "@@EVAL_NAME@@"
case_id = "@@CASE_ID@@"

[environment]
docker_image = "@@IMAGE@@"
workdir = "@@WORKDIR@@"

[verifier]
timeout_sec = @@VERIFIER_TIMEOUT@@

[agent]
timeout_sec = @@AGENT_TIMEOUT@@
